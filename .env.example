# Read'Em Environment Configuration Example
# Copy this file to '.env' and fill in your API credentials.

# OpenAI API Key (used for live worksheet OCR vision transcription and paragraph simplifications)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Exa Search API Key (used for live concept analogy web searches and educational resource citations)
VITE_EXA_API_KEY=your_exa_api_key_here

# ElevenLabs API Key (used for live high-fidelity neural text-to-speech)
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: ElevenLabs Default Model ID (defaults to eleven_turbo_v2_5 if not specified)
VITE_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
