# Read'Em Environment Configuration Example
# Copy this file to '.env' and fill in your API credentials.

# ─── OpenAI (fallback NLP & Vision OCR) ────────────────────────────────────
# Used for live paragraph simplification, word decoding analogies, and image OCR.
# Optional when Huawei Cloud proxy is configured.
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ─── ElevenLabs (optional neural TTS) ──────────────────────────────────────
# Falls back to browser Web Speech API when not set.
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
VITE_ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ─── Huawei Cloud Proxy (browser-side config) ───────────────────────────────
# Point to your server.js instance (Huawei ECS or localhost).
# The server handles AK/SK signing — these are NOT the raw Huawei credentials.
VITE_HUAWEI_ENDPOINT=http://localhost:3000
VITE_HUAWEI_API_KEY=readem-dev-key

# ─── Huawei Cloud Credentials (server-side ONLY — never prefix with VITE_) ─
# Used by server.js to sign requests to Huawei Cloud OCR and NLP APIs.
# Get these from: Huawei Cloud Console > My Credentials > Access Keys
HUAWEI_AK=your_huawei_access_key_here
HUAWEI_SK=your_huawei_secret_key_here
HUAWEI_PROJECT_ID=your_huawei_project_id_here
HUAWEI_REGION=ap-southeast-1

# Shared secret between browser and server.js proxy (change in production)
SERVER_API_KEY=readem-dev-key

# ─── Firebase (currently unused — placeholder for Phase 2 backend) ──────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
